# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.local.example

# geo data (source files from MLIT are large and manually placed)
/scripts/geo-source/*.geojson
/scripts/geo-output/
/public/geo-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
